#!/bin/bash
# --- BitNin Console Wrapper ---
# Entrypoint formal para la consola operativa.

set -e

# Resolve scripts absolute path
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_PATH/.." && pwd)"

# 1. Setup Environment
# Export PYTHONPATH so the internal imports work regardless of CWD
export PYTHONPATH="$PROJECT_ROOT"

# 2. Execute Python CLI
# We pass all arguments directly to bitnin_ctl.py
python3 "$PROJECT_ROOT/bitnin_ctl.py" "$@"
