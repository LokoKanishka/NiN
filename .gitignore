# NiN Security Gitignore
# Excluir archivos que pueden contener secretos (Tokens, OAuth, Credenciales)
diagnostics/
backups/
demon/
*.bak
*.txt
*.vscdb
*.log
*.json.bak
*.xlsx
*.pdf

# Directorios de sistema
.env
.venv/
__pycache__/
node_modules/
.DS_Store

# Temporales de operación
tmp/
/tmp/
*.lock
