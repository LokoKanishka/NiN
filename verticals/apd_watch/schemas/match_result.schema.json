{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apd_watch/match_result.schema.json",
  "title": "APD Match Result",
  "type": "object",
  "required": [
    "stable_id",
    "match_status",
    "confidence_score",
    "evaluated_at_utc"
  ],
  "properties": {
    "stable_id": { "type": "string", "minLength": 1 },
    "rule_id": { "type": ["string", "null"] },
    "match_type": {
      "type": ["string", "null"],
      "enum": ["exact", "normalized", "fuzzy", "manual_review", null]
    },
    "match_status": {
      "type": "string",
      "enum": ["seguro", "probable", "ambigua", "no_match"]
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason": { "type": "string" },
    "evaluated_at_utc": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
