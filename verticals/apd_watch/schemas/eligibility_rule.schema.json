{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apd_watch/eligibility_rule.schema.json",
  "title": "APD Eligibility Rule",
  "type": "object",
  "required": [
    "rule_id",
    "official_name",
    "match_type",
    "priority",
    "confidence_band",
    "enabled"
  ],
  "properties": {
    "rule_id": { "type": "string", "minLength": 1 },
    "official_name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "code": { "type": ["string", "null"] },
    "level_modality": { "type": ["string", "null"] },
    "match_type": {
      "type": "string",
      "enum": ["exact", "normalized", "fuzzy", "manual_review"]
    },
    "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
    "confidence_band": {
      "type": "string",
      "enum": ["segura", "probable", "ambigua"]
    },
    "notes": { "type": "string" },
    "enabled": { "type": "boolean" },
    "effective_date": { "type": ["string", "null"], "format": "date" }
  },
  "additionalProperties": true
}
