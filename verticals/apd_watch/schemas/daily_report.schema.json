{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apd_watch/daily_report.schema.json",
  "title": "APD Daily Report",
  "type": "object",
  "required": [
    "report_date",
    "generated_at_utc",
    "totals",
    "highlights"
  ],
  "properties": {
    "report_date": { "type": "string", "format": "date" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "totals": {
      "type": "object",
      "required": ["offers_seen", "matches_total", "new_today"],
      "properties": {
        "offers_seen": { "type": "integer", "minimum": 0 },
        "matches_total": { "type": "integer", "minimum": 0 },
        "new_today": { "type": "integer", "minimum": 0 },
        "urgent_closing": { "type": "integer", "minimum": 0 },
        "ambiguous": { "type": "integer", "minimum": 0 },
        "annulled_or_expired": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifact_refs": {
      "type": "object",
      "properties": {
        "snapshot_raw": { "type": "string" },
        "snapshot_normalized": { "type": "string" },
        "matches": { "type": "string" },
        "diff": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
