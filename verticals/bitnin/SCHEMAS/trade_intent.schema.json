{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Trade Intent v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "mode",
    "action",
    "entry_reference",
    "valid_until",
    "reasoning_ref",
    "approved",
    "created_at",
    "status"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "simulation",
        "shadow"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "buy",
        "sell",
        "reduce",
        "exit",
        "hold",
        "no_trade"
      ]
    },
    "entry_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "interval",
        "timestamp",
        "price"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "price": {
          "type": "number"
        }
      }
    },
    "stop_reference": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/priceReference"
        }
      ]
    },
    "take_profit_reference": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/priceReference"
        }
      ]
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "reasoning_ref": {
      "type": "string",
      "minLength": 1
    },
    "approved": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "expired",
        "reviewed",
        "invalidated"
      ]
    },
    "final_status": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "priceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "price"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "price": {
          "type": "number"
        }
      }
    }
  }
}
