{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Approval v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "intent_id",
    "status",
    "actor",
    "timestamp",
    "notes"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "awaiting_human_approval",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "message_ref": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "reasoning_ref": {
      "type": "string",
      "minLength": 1
    },
    "shadow_ref": {
      "type": "string",
      "minLength": 1
    }
  }
}
