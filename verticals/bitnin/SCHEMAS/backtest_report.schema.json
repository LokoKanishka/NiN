{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Backtest Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "metrics",
    "baselines",
    "success_definition",
    "non_claims"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object"
    },
    "baselines": {
      "type": "object"
    },
    "success_definition": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
