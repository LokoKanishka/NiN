{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Execution Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "intent_id",
    "executed_at",
    "status",
    "execution_mode",
    "result_ref",
    "notes"
  ],
  "properties": {
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted_dry_run",
        "rejected",
        "invalid_intent",
        "expired",
        "guardrail_blocked"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "simulation",
        "shadow",
        "dry_run"
      ]
    },
    "result_ref": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "request_ref": {
      "type": "string",
      "minLength": 1
    },
    "validated_guards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejection_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dry_run": {
      "type": "boolean"
    },
    "executor_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
