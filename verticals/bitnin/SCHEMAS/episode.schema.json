{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Episode v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "window_start",
    "window_end",
    "market_signature",
    "narrative_signature",
    "summary_local",
    "outcome",
    "sources",
    "dataset_version"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "window_start": {
      "type": "string",
      "format": "date-time"
    },
    "window_end": {
      "type": "string",
      "format": "date-time"
    },
    "market_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interval",
        "return_1d",
        "return_3d",
        "return_7d",
        "volatility_regime",
        "drawdown_pre",
        "breakout",
        "volume_anomaly",
        "volume_anomaly_score"
      ],
      "properties": {
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "return_1d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "return_3d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "return_7d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "volatility_regime": {
          "type": "string",
          "minLength": 1
        },
        "drawdown_pre": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "breakout": {
          "type": "boolean"
        },
        "volume_anomaly": {
          "type": "boolean"
        },
        "volume_anomaly_score": {
          "type": "number"
        }
      }
    },
    "narrative_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topics",
        "entities",
        "dominant_cause",
        "narrative_confidence",
        "event_count"
      ],
      "properties": {
        "topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dominant_cause": {
          "type": "string",
          "minLength": 1
        },
        "narrative_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary_local": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forward_return_1d",
        "forward_return_7d",
        "forward_return_30d",
        "forward_max_up",
        "forward_max_down",
        "continuation_or_reversion"
      ],
      "properties": {
        "forward_return_1d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "forward_return_7d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "forward_return_30d": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "forward_max_up": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "forward_max_down": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "continuation_or_reversion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dataset_version": {
      "type": "string",
      "minLength": 1
    },
    "trigger_type": {
      "type": "string",
      "minLength": 1
    },
    "trigger_strength": {
      "type": "number"
    },
    "market_source_ref": {
      "type": "string",
      "minLength": 1
    },
    "narrative_source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "ambiguous",
        "discarded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
