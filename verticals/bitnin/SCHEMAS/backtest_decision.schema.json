{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Backtest Decision v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "analysis_ref",
    "timestamp",
    "decision",
    "entry_reference",
    "outcome",
    "evaluation_window",
    "result_status",
    "dataset_versions"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_ref": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "recommended_action",
        "final_status",
        "confidence"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "minLength": 1
        },
        "recommended_action": {
          "type": "string",
          "minLength": 1
        },
        "final_status": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "entry_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "interval",
        "close_time",
        "close"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "close_time": {
          "type": "string",
          "format": "date-time"
        },
        "close": {
          "type": "number"
        }
      }
    },
    "outcome": {
      "type": "object"
    },
    "evaluation_window": {
      "type": "object"
    },
    "result_status": {
      "type": "string",
      "minLength": 1
    },
    "market_state": {
      "type": "object"
    },
    "retrieved_episode_count": {
      "type": "integer",
      "minimum": 0
    },
    "top_retrieval_score": {
      "type": "number",
      "minimum": 0
    },
    "data_coverage_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "narrative_coverage_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "dataset_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
