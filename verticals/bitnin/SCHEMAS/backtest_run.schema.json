{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BitNin Backtest Run v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "symbol",
    "interval",
    "replay_start",
    "replay_end",
    "step_count",
    "dataset_versions"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "interval": {
      "type": "string",
      "minLength": 1
    },
    "replay_start": {
      "type": "string",
      "format": "date-time"
    },
    "replay_end": {
      "type": "string",
      "format": "date-time"
    },
    "step_count": {
      "type": "integer",
      "minimum": 0
    },
    "dataset_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
